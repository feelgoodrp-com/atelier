<?xml version="1.0" encoding="utf-8"?>
<!--
  The machine-level NuGet config on dev machines may list a stale local source
  ("C:\Program Files (x86)\Microsoft SDKs\NuGetPackages") which breaks restore
  with NU1301. Clear inherited sources and use nuget.org only.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
